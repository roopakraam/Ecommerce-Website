# Public site URL used for sitemap, canonicals, and Open Graph
# Local: http://localhost:3000
# Vercel (no custom domain yet): https://YOUR_PROJECT.vercel.app
# Custom domain later: https://www.bookmytees.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Project URL only (no /rest/v1/ suffix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Use the service_role key (not the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Webhook secret from Razorpay Dashboard → Settings → Webhooks
# Endpoint (no purchased domain needed): https://YOUR_PROJECT.vercel.app/api/payments/razorpay/webhook
# Subscribe to: payment.captured
# Optional until webhook is created; required before real customer traffic
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Resend — https://resend.com/api-keys (optional; stubs if unset)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=BOOK MY TEES <orders@yourdomain.com>

# Twilio WhatsApp — https://console.twilio.com (optional; stubs if unset)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# E.164 or whatsapp:+14155238886 (Twilio sandbox / approved sender)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Integrations hub — encrypts API secrets saved in Admin → Integrations
# Generate: openssl rand -base64 32
# Required to save credentials in the database; env vars above remain a fallback
INTEGRATIONS_ENCRYPTION_KEY=

# Vercel Cron — Authorization: Bearer <CRON_SECRET> for /api/cron/*
# Generate: openssl rand -base64 32
# Required in Production so the stale-inventory cron can run securely
CRON_SECRET=

# Health probes (no extra secrets required)
# Liveness:  GET /api/livez  (also /api/health, /api/healthz)
# Readiness: GET /api/readyz (checks Supabase connectivity)
